#!/usr/bin/env bash

set -euo pipefail

# Resolve script path (follow symlinks) so lib/ is found when invoked via symlink (e.g. ~/.local/bin/vaultsh)
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR_TMP="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR_TMP/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"
HAS_FZF=0

# shellcheck source=/dev/null
source "${LIB_DIR}/core.sh"
# shellcheck source=/dev/null
source "${LIB_DIR}/ui.sh"
# shellcheck source=/dev/null
source "${LIB_DIR}/ops.sh"
# shellcheck source=/dev/null
source "${LIB_DIR}/nav.sh"

vaultsh_usage() {
  cat <<EOF
Usage: $(basename "$0") [--help] [session-check|read|browse] [options]

HashiCorp Vault CLI assistant for interactive use.

Subcommands (optional; without one, the interactive menu starts):
  session-check    Show whether you are logged in (token state or KV probe).
  read             Read a secret; use --path and optionally --field.
  browse           Start the KV path browser.

Options for read:
  --path, -p PATH  Secret path (required).
  --field, -f NAME Secret field (optional; omit for full secret).

  - OIDC login (configurable reader/operator roles)
  - Session check and token/status inspection
  - Browse KV paths and read secrets
  - Read/write KV secrets (path and field chosen each time)
  - Diagnostics for connectivity and token issues

Not intended for automation or CI; use the vault CLI directly there.
EOF
}

vaultsh_show_main_hint() {
  local token_state
  token_state="$(vaultsh_token_state)"

  vaultsh_print_panel \
    "session" \
    "Login, then browse, read or write secrets at any KV path." \
    "Use diagnostics when auth succeeds but CLI reads fail."

  vaultsh_print_panel \
    "recommended next" \
    "$(vaultsh_recommended_next_line_one "${token_state}")" \
    "$(vaultsh_recommended_next_line_two "${token_state}")"
  echo
}

vaultsh_recommended_next_line_one() {
  local token_state="$1"
  case "$token_state" in
    missing)
      printf '%s\n' "1. Open Login and start an OIDC reader session."
      ;;
    file|env)
      printf '%s\n' "1. Browse KV or read a secret, or inspect token details."
      ;;
    *)
      printf '%s\n' "1. Start with Login to establish a clean Vault session."
      ;;
  esac
}

vaultsh_recommended_next_line_two() {
  local token_state="$1"
  case "$token_state" in
    missing)
      printf '%s\n' "2. Run diagnostics if you expect a token but reads still fail."
      ;;
    file|env)
      printf '%s\n' "2. Use diagnostics before changing policies or secret paths."
      ;;
    *)
      printf '%s\n' "2. Review quick commands if you prefer the raw CLI path."
      ;;
  esac
}

vaultsh_handle_login_menu() {
  local choice=""
  vaultsh_show_guidance \
    "login" \
    "Reader is for normal daily access. Operator is for controlled writes and maintenance." \
    "The browser flow should open automatically once you pick a role."
  choice="$(vaultsh_select_option \
    "Login menu" \
    "1|OIDC login as ${VAULTSH_READER_ROLE}|Read-only everyday session for secret access and checks." \
    "2|OIDC login as ${VAULTSH_OPERATOR_ROLE}|Privileged session for updates, rotations, and maintenance." \
    "b|Back|Return to the main menu without opening a browser flow.")" || return 0

  case "$choice" in
    1)
      vaultsh_login_role "${VAULTSH_READER_ROLE}"
      ;;
    2)
      vaultsh_login_role "${VAULTSH_OPERATOR_ROLE}"
      ;;
    *)
      return 0
      ;;
  esac

  vaultsh_pause
}

vaultsh_handle_status_menu() {
  local choice=""
  vaultsh_show_guidance \
    "status" \
    "Use this when you want confidence about the current session before touching secrets." \
    "Session check shows at a glance whether you are still logged in or need to log in."
  choice="$(vaultsh_select_option \
    "Status and token" \
    "1|Session check|Show whether the session is valid or you need to log in." \
    "2|vault status|Check connectivity, seal state, and core server health." \
    "3|vault token lookup|Inspect the current token, policies, and expiry." \
    "4|Run both|A quick read on connection plus identity state." \
    "b|Back|Return to the main menu.")" || return 0

  set +e
  case "$choice" in
    1)
      vaultsh_session_check || true
      ;;
    2)
      vaultsh_show_status || true
      ;;
    3)
      vaultsh_show_token_lookup || true
      ;;
    4)
      vaultsh_show_status || true
      echo
      vaultsh_show_token_lookup || true
      ;;
    *)
      set -e
      return 0
      ;;
  esac
  set -e

  vaultsh_pause
}

vaultsh_handle_read_secret() {
  local path field rc
  vaultsh_show_guidance \
    "read" \
    "Enter a secret path and optionally a field name (leave field empty for full secret)." \
    ""

  if ! vaultsh_ensure_session; then
    vaultsh_pause
    return 0
  fi

  path="$(vaultsh_prompt "Secret path (Enter to browse)" "")"
  if [[ -z "$path" ]]; then
    vaultsh_nav_pick_path
    if [[ -n "${VAULTSH_PICKED_PATH:-}" ]]; then
      path="$VAULTSH_PICKED_PATH"
      unset -v VAULTSH_PICKED_PATH
    else
      return 0
    fi
  fi
  field="$(vaultsh_prompt "Optional field (Enter to browse, empty = full secret)" "")"
  if [[ -z "$field" ]] && [[ -n "$path" ]]; then
    if vaultsh_pick_field "$path" "read"; then
      field="${VAULTSH_PICKED_FIELD:-}"
      unset -v VAULTSH_PICKED_FIELD
    fi
  fi
  set +e
  vaultsh_read_secret "$path" "$field"
  rc=$?
  set -e
  if (( rc != 0 )); then
    if vaultsh_offer_login "Session may have expired or access denied."; then
      vaultsh_read_secret "$path" "$field"
    fi
  fi
  vaultsh_pause
}

vaultsh_handle_write_secret() {
  local path field value rc
  local -a preview_cmd
  vaultsh_show_guidance \
    "write" \
    "Writes are previewed first and stay intentionally explicit." \
    "Use operator access before attempting updates or rotations."

  if ! vaultsh_ensure_session; then
    vaultsh_pause
    return 0
  fi

  path="$(vaultsh_prompt "Secret path (Enter to browse)" "")"
  if [[ -z "$path" ]]; then
    vaultsh_nav_pick_path
    if [[ -n "${VAULTSH_PICKED_PATH:-}" ]]; then
      path="$VAULTSH_PICKED_PATH"
      unset -v VAULTSH_PICKED_PATH
    fi
  fi
  field="$(vaultsh_prompt "Field name (Enter to browse)" "")"
  if [[ -z "$field" ]] && [[ -n "$path" ]]; then
    if vaultsh_pick_field "$path" "write"; then
      field="${VAULTSH_PICKED_FIELD:-}"
      unset -v VAULTSH_PICKED_FIELD
    fi
  fi
  if [[ "$field" == "(type new field)" ]]; then
    field="$(vaultsh_prompt "Field name" "")"
  fi
  if [[ -z "$path" || -z "$field" ]]; then
    vaultsh_warn "Path and field are required. Skipping write."
    vaultsh_pause
    return 0
  fi
  value="$(vaultsh_prompt_secret "Field value (hidden)")"
  preview_cmd=(vault kv put "$path" "${field}=***")
  vaultsh_print_preview "write secret" "${preview_cmd[@]}"
  if vaultsh_confirm "Execute this write" "N"; then
    set +e
    vaultsh_write_secret_value "$path" "$field" "$value"
    rc=$?
    set -e
    if (( rc != 0 )); then
      if vaultsh_offer_login "Session may have expired or access denied."; then
        vaultsh_write_secret_value "$path" "$field" "$value"
      fi
    fi
  fi

  vaultsh_pause
}

vaultsh_handle_help() {
  vaultsh_print_panel "config"
  vaultsh_print_kv "address" "${VAULTSH_ADDR}"
  vaultsh_print_kv "reader" "${VAULTSH_READER_ROLE}"
  vaultsh_print_kv "operator" "${VAULTSH_OPERATOR_ROLE}"
  vaultsh_print_kv "nav root" "${VAULTSH_NAV_ROOT}"
  if [[ -n "${VAULTSH_SESSION_PROBE_PATH:-}" ]]; then
    vaultsh_print_kv "session probe" "${VAULTSH_SESSION_PROBE_PATH}:${VAULTSH_SESSION_PROBE_FIELD:-}"
  fi
  printf '%s-------------------------------------------------------------------------------%s\n' "$COLOR_PANEL" "$COLOR_RESET"

  echo
  vaultsh_print_quick_commands
  vaultsh_pause
}

vaultsh_handle_palette() {
  local choice=""

  vaultsh_show_guidance \
    "quick open" \
    "Jump straight to common actions by intent." \
    "Pick a task instead of walking the whole menu tree."

  choice="$(vaultsh_select_option \
    "Quick open" \
    "1|Login as reader|Open an OIDC reader session immediately." \
    "2|Login as operator|Open an OIDC operator session immediately." \
    "3|Browse KV|Navigate through Vault KV paths and read secrets." \
    "4|Read secret|Prompt for path and optional field, then read." \
    "5|Run diagnostics|Bundle the common health, token, and secret checks." \
    "6|Session check|Show whether you are still logged in or need to log in." \
    "7|Open write flow|Go directly to the write/update menu." \
    "8|Quick commands|Show the equivalent manual CLI commands." \
    "b|Back|Return to the main menu.")" || return 0

  case "$choice" in
    1)
      vaultsh_login_role "${VAULTSH_READER_ROLE}"
      vaultsh_pause
      ;;
    2)
      vaultsh_login_role "${VAULTSH_OPERATOR_ROLE}"
      vaultsh_pause
      ;;
    3)
      vaultsh_nav_run
      vaultsh_pause
      ;;
    4)
      vaultsh_handle_read_secret
      ;;
    5)
      vaultsh_run_diagnostics
      vaultsh_pause
      ;;
    6)
      vaultsh_session_check || true
      vaultsh_pause
      ;;
    7)
      vaultsh_handle_write_secret
      ;;
    8)
      vaultsh_handle_help
      ;;
    *)
      return 0
      ;;
  esac
}

vaultsh_main_menu() {
  local choice=""

  while true; do
    vaultsh_print_header
    vaultsh_show_main_hint
    choice="$(vaultsh_select_option \
      "Main menu" \
      "p|Quick open palette|Jump straight to common actions by intent." \
      "1|Login and identity|Open an OIDC session as reader or operator." \
      "2|Token and status checks|Inspect connection, current token, and Vault health." \
      "3|Browse / Navigate|Navigate KV paths and read secrets." \
      "4|Read secret|Enter path and optional field to read a secret." \
      "5|Write or update secret|Perform controlled writes with preview and confirmation." \
      "6|Run diagnostics|Bundle the common checks for 403s, missing tokens, and wrong paths." \
      "7|Show quick commands|Print the equivalent manual CLI commands." \
      "q|Quit|Leave the interactive shell.")" || break

    case "$choice" in
      p|P)
        vaultsh_handle_palette
        ;;
      1)
        vaultsh_handle_login_menu
        ;;
      2)
        vaultsh_handle_status_menu
        ;;
      3)
        vaultsh_nav_run
        vaultsh_pause
        ;;
      4)
        vaultsh_handle_read_secret
        ;;
      5)
        vaultsh_handle_write_secret
        ;;
      6)
        vaultsh_run_diagnostics
        vaultsh_pause
        ;;
      7)
        vaultsh_handle_help
        ;;
      q|Q)
        break
        ;;
      *)
        vaultsh_warn "Unknown menu choice: ${choice}"
        vaultsh_pause
        ;;
    esac
  done
}

main() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    vaultsh_usage
    exit 0
  fi

  vaultsh_load_config "$SCRIPT_DIR"
  vaultsh_init_theme
  vaultsh_detect_fzf

  vaultsh_require_command vault

  case "${1:-}" in
    session-check|session_check)
      shift
      vaultsh_session_check
      exit $?
      ;;
    read)
      shift
      run_read_subcommand "$@"
      exit $?
      ;;
    browse)
      shift
      vaultsh_nav_run
      exit $?
      ;;
  esac

  vaultsh_main_menu
}

run_read_subcommand() {
  local path=""
  local field=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path|-p)
        path="${2:-}"
        shift 2
        ;;
      --field|-f)
        field="${2:-}"
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done
  if [[ -z "$path" ]]; then
    vaultsh_error "read subcommand requires --path (or -p). Example: vaultsh read -p kv/myapp"
    exit 1
  fi
  vaultsh_read_secret "$path" "$field"
}

main "$@"
